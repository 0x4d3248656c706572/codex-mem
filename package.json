{
  "name": "codex-mem",
  "version": "12.1.0",
  "description": "Persistent memory for Codex",
  "keywords": [
    "codex",
    "codex-cli",
    "mcp",
    "memory",
    "context",
    "developer-tools",
    "agent-memory",
    "local-first",
    "transcript",
    "nodejs"
  ],
  "author": "0x4d3248656c706572",
  "license": "AGPL-3.0",
  "homepage": "https://github.com/0x4d3248656c706572/codex-mem",
  "repository": {
    "type": "git",
    "url": "https://github.com/0x4d3248656c706572/codex-mem.git"
  },
  "bugs": {
    "url": "https://github.com/0x4d3248656c706572/codex-mem/issues"
  },
  "type": "module",
  "bin": {
    "codex-mem": "./index.js"
  },
  "files": [
    ".codex-plugin",
    "index.js",
    "plugin/package.json",
    "plugin/hooks",
    "plugin/modes",
    "plugin/scripts/*.js",
    "plugin/scripts/*.cjs",
    "plugin/skills",
    "plugin/ui"
  ],
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "scripts": {
    "worker:start": "bun plugin/scripts/worker-service.cjs start",
    "worker:stop": "bun plugin/scripts/worker-service.cjs stop",
    "worker:restart": "bun plugin/scripts/worker-service.cjs restart",
    "worker:status": "bun plugin/scripts/worker-service.cjs status",
    "pack:check": "npm pack --dry-run"
  }
}
